// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  // output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ═══════════════════════════════
//  UTILISATEURS
// ═══════════════════════════════
model User {
  id        Int      @id @default(autoincrement())
  nom       String
  email     String   @unique
  motDePasse String
  role      Role     @default(CLIENT)
  adresse   String
  createdAt DateTime @default(now())

  commandes Commande[]
  panier    CartItem[]
}

enum Role {
  CLIENT
  ADMIN
}

// ═══════════════════════════════
//  PRODUITS
// ═══════════════════════════════
model Produit {
    id          Int       @id @default(autoincrement())
  nom         String
  description String?
  prix        Float
  image       String?
  categorie   Categorie
  disponible  Boolean   @default(true)
  createdAt   DateTime  @default(now())

  variantes     VarianteProduit[]
  commandeItems CommandeItem[]
  cartItems     CartItem[]
}

enum Categorie {
  GATEAU    // taille unique, saveur personnalisable
  DONUT     // box de 6, garniture personnalisable
  BEIGNET   // vendu par quantité fixe (45 ou 100)
}

// ═══════════════════════════════
//  VARIANTES & PERSONNALISATION
// ═══════════════════════════════
model VarianteProduit {
   id          Int     @id @default(autoincrement())
  produitId   Int
  nom         String  // "Nature", "Chocolat", "Fourré vanille", "45 pièces"
  prix        Float   // prix exact de cette variante
  estDefaut   Boolean @default(false) // variante sélectionnée par défaut
  disponible  Boolean @default(true)

  produit   Produit    @relation(fields: [produitId], references: [id])
  cartItems CartItem[]
  commandeItems CommandeItem[]
}

// ═══════════════════════════════
//  PANIER
// ═══════════════════════════════
model CartItem {
   id          Int     @id @default(autoincrement())
  userId      Int
  produitId   Int
  varianteId  Int     // variante choisie (saveur, garniture, quantité)
  quantite    Int     @default(1)

  user      User            @relation(fields: [userId], references: [id])
  produit   Produit         @relation(fields: [produitId], references: [id])
  variante  VarianteProduit @relation(fields: [varianteId], references: [id])
}

// ═══════════════════════════════
//  COMMANDES
// ═══════════════════════════════
model Commande {
  id          Int            @id @default(autoincrement())
  userId      Int
  statut      Statut         @default(RECUE)
  total       Float
  dateRetrait DateTime?
  createdAt   DateTime       @default(now())
  stripeId    String?        // ID paiement Stripe

  user  User           @relation(fields: [userId], references: [id])
  items CommandeItem[]
}

enum Statut {
  RECUE
  EN_PREPARATION
  PRETE
  LIVREE
  ANNULEE
}

// ═══════════════════════════════
//  DÉTAIL COMMANDE
// ═══════════════════════════════
model CommandeItem {
  id         Int   @id @default(autoincrement())
  commandeId Int
  produitId  Int
  varianteId Int
  quantite   Int
  prixUnitaire Float  // prix sauvegardé au moment de la commande

  commande Commande        @relation(fields: [commandeId], references: [id])
  produit  Produit         @relation(fields: [produitId], references: [id])
  variante VarianteProduit @relation(fields: [varianteId], references: [id])
}
